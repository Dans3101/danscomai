# Copy to bridge/.env and fill in from the Accounts -> Bridge config panel.
APP_BASE_URL=https://your-app.lovable.app
ACCOUNT_ID=
BRIDGE_TOKEN=

# MT5 broker credentials (any broker: XM, Exness, IC Markets, Deriv, ...).
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Backend selector: auto | native | mt5linux | simulator
#   auto      — native on Windows, mt5linux on Linux
#   simulator — run without a broker (dev/test mode)
MT5_BACKEND=auto

# mt5linux RPyC endpoint (Ubuntu + Wine deployment).
MT5LINUX_HOST=127.0.0.1
MT5LINUX_PORT=18812

# Path to the MT5 terminal executable. On Linux this is the Wine path,
# e.g. C:\\Program Files\\MetaTrader 5\\terminal64.exe (blank = autodetect).
MT5_PATH=

POLL_SECONDS=2
HEALTH_FILE=/tmp/mt5-bridge.health
LOG_LEVEL=INFO

# Prometheus metrics (scraped by Grafana)
METRICS_ENABLED=1
METRICS_PORT=9108